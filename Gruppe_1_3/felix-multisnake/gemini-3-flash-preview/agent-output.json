{"type":"tool_use","timestamp":1777038218544,"sessionID":"ses_24044ebb0ffe3xc67TJAedk1gX","part":{"type":"tool","tool":"write","callID":"call_MHwxVzE1UDFSa2NSclFka1Q0Vk4","state":{"status":"completed","input":{"content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Retro Snake</title>\n    <style>\n        :root {\n            --bg-color: #1a1a1a;\n            --panel-color: #2a2a2a;\n            --text-color: #eee;\n            --accent-color: #4CAF50;\n            --danger-color: #e74c3c;\n            --snake-head: #81C784;\n            --snake-body: #4CAF50;\n            --food-color: #ff5252;\n        }\n\n        body {\n            background-color: var(--bg-color);\n            color: var(--text-color);\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            margin: 0;\n            overflow: hidden;\n        }\n\n        #game-container {\n            position: relative;\n            background-color: var(--panel-color);\n            padding: 20px;\n            border-radius: 12px;\n            box-shadow: 0 10px 30px rgba(0,0,0,0.5);\n            text-align: center;\n        }\n\n        .stats {\n            display: flex;\n            justify-content: space-between;\n            margin-bottom: 15px;\n            font-size: 1.2rem;\n            font-weight: bold;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n        }\n\n        canvas {\n            background-color: #000;\n            border: 4px solid #333;\n            border-radius: 4px;\n            display: block;\n        }\n\n        #overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: rgba(0,0,0,0.8);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            border-radius: 12px;\n            visibility: hidden;\n            opacity: 0;\n            transition: opacity 0.3s ease;\n        }\n\n        #overlay.visible {\n            visibility: visible;\n            opacity: 1;\n        }\n\n        h1 { margin: 0 0 10px 0; color: var(--accent-color); }\n        \n        button {\n            background-color: var(--accent-color);\n            color: white;\n            border: none;\n            padding: 12px 24px;\n            font-size: 1.1rem;\n            border-radius: 6px;\n            cursor: pointer;\n            transition: transform 0.1s, background-color 0.2s;\n            font-weight: bold;\n        }\n\n        button:hover { background-color: #45a049; }\n        button:active { transform: scale(0.95); }\n\n        .controls-hint {\n            margin-top: 15px;\n            font-size: 0.8rem;\n            color: #888;\n        }\n    </style>\n</head>\n<body>\n\n    <div id=\"game-container\">\n        <div class=\"stats\">\n            <div>Score: <span id=\"score\">0</span></div>\n            <div>Best: <span id=\"high-score\">0</span></div>\n        </div>\n        \n        <canvas id=\"gameCanvas\" width=\"400\" height=\"400\"></canvas>\n\n        <div id=\"overlay\">\n            <h1 id=\"status-text\">GAME OVER</h1>\n            <p>Score: <span id=\"final-score\">0</span></p>\n            <button id=\"restart-btn\">START GAME</button>\n        </div>\n\n        <div class=\"controls-hint\">Use Arrow Keys to Move</div>\n    </div>\n\n    <script>\n        const canvas = document.getElementById('gameCanvas');\n        const ctx = canvas.getContext('2d');\n        const scoreEl = document.getElementById('score');\n        const highScoreEl = document.getElementById('high-score');\n        const finalScoreEl = document.getElementById('final-score');\n        const overlay = document.getElementById('overlay');\n        const statusText = document.getElementById('status-text');\n        const restartBtn = document.getElementById('restart-btn');\n\n        const gridSize = 20;\n        const tileCount = canvas.width / gridSize;\n\n        let score = 0;\n        let highScore = localStorage.getItem('snakeHighScore') || 0;\n        let snake = [];\n        let food = { x: 5, y: 5 };\n        let dx = 0;\n        let dy = 0;\n        let nextDx = 0;\n        let nextDy = 0;\n        let gameLoop;\n        let isPaused = true;\n\n        highScoreEl.textContent = highScore;\n\n        function initGame() {\n            snake = [\n                { x: 10, y: 10 },\n                { x: 10, y: 11 },\n                { x: 10, y: 12 }\n            ];\n            score = 0;\n            scoreEl.textContent = score;\n            nextDx = 0;\n            nextDy = -1; // Start moving up\n            dx = 0;\n            dy = 0;\n            placeFood();\n            isPaused = false;\n            overlay.classList.remove('visible');\n            if (gameLoop) clearInterval(gameLoop);\n            gameLoop = setInterval(draw, 100);\n        }\n\n        function placeFood() {\n            food = {\n                x: Math.floor(Math.random() * tileCount),\n                y: Math.floor(Math.random() * tileCount)\n            };\n            // Prevent food from spawning on snake\n            snake.forEach(part => {\n                if (part.x === food.x && part.y === food.y) placeFood();\n            });\n        }\n\n        function draw() {\n            update();\n            if (checkGameOver()) {\n                endGame();\n                return;\n            }\n            clearCanvas();\n            drawFood();\n            drawSnake();\n        }\n\n        function clearCanvas() {\n            ctx.fillStyle = \"black\";\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n            \n            // Subtle grid\n            ctx.strokeStyle = \"#111\";\n            ctx.lineWidth = 1;\n            for(let i=0; i<canvas.width; i+=gridSize) {\n                ctx.beginPath(); ctx.moveTo(i,0); ctx.lineTo(i, canvas.height); ctx.stroke();\n                ctx.beginPath(); ctx.moveTo(0,i); ctx.lineTo(canvas.width, i); ctx.stroke();\n            }\n        }\n\n        function update() {\n            dx = nextDx;\n            dy = nextDy;\n\n            const head = { x: snake[0].x + dx, y: snake[0].y + dy };\n            snake.unshift(head);\n\n            if (head.x === food.x && head.y === food.y) {\n                score += 10;\n                scoreEl.textContent = score;\n                if (score > highScore) {\n                    highScore = score;\n                    highScoreEl.textContent = highScore;\n                    localStorage.setItem('snakeHighScore', highScore);\n                }\n                placeFood();\n            } else {\n                snake.pop();\n            }\n        }\n\n        function drawSnake() {\n            snake.forEach((part, index) => {\n                ctx.fillStyle = index === 0 ? '#81C784' : '#4CAF50';\n                // Draw rounded rect for snake parts\n                const r = 4;\n                const x = part.x * gridSize + 1;\n                const y = part.y * gridSize + 1;\n                const s = gridSize - 2;\n                \n                ctx.beginPath();\n                ctx.roundRect(x, y, s, s, r);\n                ctx.fill();\n            });\n        }\n\n        function drawFood() {\n            ctx.fillStyle = \"#ff5252\";\n            ctx.beginPath();\n            const centerX = food.x * gridSize + gridSize/2;\n            const centerY = food.y * gridSize + gridSize/2;\n            ctx.arc(centerX, centerY, gridSize/2 - 2, 0, Math.PI * 2);\n            ctx.fill();\n            \n            // Add a little shine to food\n            ctx.fillStyle = \"rgba(255,255,255,0.3)\";\n            ctx.beginPath();\n            ctx.arc(centerX - 3, centerY - 3, 2, 0, Math.PI * 2);\n            ctx.fill();\n        }\n\n        function checkGameOver() {\n            const head = snake[0];\n            // Wall collision\n            if (head.x < 0 || head.x >= tileCount || head.y < 0 || head.y >= tileCount) return true;\n            // Self collision\n            for (let i = 1; i < snake.length; i++) {\n                if (snake[i].x === head.x && snake[i].y === head.y) return true;\n            }\n            return false;\n        }\n\n        function endGame() {\n            clearInterval(gameLoop);\n            isPaused = true;\n            statusText.textContent = \"GAME OVER\";\n            finalScoreEl.textContent = score;\n            restartBtn.textContent = \"TRY AGAIN\";\n            overlay.classList.add('visible');\n        }\n\n        window.addEventListener('keydown', e => {\n            switch(e.key) {\n                case 'ArrowUp':\n                    if (dy !== 1) { nextDx = 0; nextDy = -1; }\n                    break;\n                case 'ArrowDown':\n                    if (dy !== -1) { nextDx = 0; nextDy = 1; }\n                    break;\n                case 'ArrowLeft':\n                    if (dx !== 1) { nextDx = -1; nextDy = 0; }\n                    break;\n                case 'ArrowRight':\n                    if (dx !== -1) { nextDx = 1; nextDy = 0; }\n                    break;\n            }\n        });\n\n        restartBtn.addEventListener('click', initGame);\n\n        // Initial state\n        clearCanvas();\n        overlay.classList.add('visible');\n        statusText.textContent = \"SNAKE\";\n        restartBtn.textContent = \"START GAME\";\n    </script>\n</body>\n</html>\n","filePath":"/Users/t969275/Code/Scienta/multisnake/gemini-3-flash-preview/index.html"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/t969275/Code/Scienta/multisnake/gemini-3-flash-preview/index.html","exists":false,"truncated":false},"title":"Users/t969275/Code/Scienta/multisnake/gemini-3-flash-preview/index.html","time":{"start":1777038218535,"end":1777038218543}},"metadata":{"copilot":{"reasoningOpaque":""}},"id":"prt_dbfbb5522001moK42kdhWIRfV2","sessionID":"ses_24044ebb0ffe3xc67TJAedk1gX","messageID":"msg_dbfbb18f50018dDBfteGP82RsS"}}
{"type":"text","timestamp":1777038218600,"sessionID":"ses_24044ebb0ffe3xc67TJAedk1gX","part":{"id":"prt_dbfbb27150011kMdHTsFw4fdWA","messageID":"msg_dbfbb18f50018dDBfteGP82RsS","sessionID":"ses_24044ebb0ffe3xc67TJAedk1gX","type":"text","text":"I'll create a polished, self-contained Snake game in `index.html`.\n\n### Plan\n1.  **HTML Structure:** Create a container with a canvas for the game grid and a header for the score.\n2.  **CSS Styling:** Apply a modern, dark-themed aesthetic with centered layout and responsive canvas sizing.\n3.  **JavaScript Logic:**\n    *   Game loop with a fixed frame rate.\n    *   Snake movement, growth, and collision detection (walls and self).\n    *   Food generation.\n    *   Keyboard input handling for arrow keys.\n    *   Score tracking and high score persistence (using local storage).\n    *   Game over and restart logic.\n\nI will now write the file to the current directory.\n\n","time":{"start":1777038206741,"end":1777038218598}}}
