{"type":"tool_use","timestamp":1777038249045,"sessionID":"ses_24044e3ebffeI2SkdKQLUEjELW","part":{"type":"tool","tool":"write","callID":"toolu_bdrk_01MRPk4DP7xJU5ibH6wvJRLh","state":{"status":"completed","input":{"filePath":"/Users/t969275/Code/Scienta/multisnake/claude-sonnet-4.6/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Snake</title>\n  <style>\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n    body {\n      background: #0f0f1a;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      min-height: 100vh;\n      font-family: 'Segoe UI', system-ui, sans-serif;\n      color: #e0e0e0;\n      user-select: none;\n    }\n\n    h1 {\n      font-size: 2.4rem;\n      font-weight: 800;\n      letter-spacing: 0.12em;\n      text-transform: uppercase;\n      background: linear-gradient(135deg, #4ade80, #22d3ee);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n      margin-bottom: 0.5rem;\n    }\n\n    #scoreboard {\n      display: flex;\n      gap: 2.5rem;\n      margin-bottom: 1rem;\n      font-size: 0.9rem;\n      letter-spacing: 0.06em;\n      text-transform: uppercase;\n      color: #888;\n    }\n\n    #scoreboard span { color: #e0e0e0; font-weight: 700; font-size: 1.05rem; }\n\n    #arena {\n      position: relative;\n      border-radius: 12px;\n      overflow: hidden;\n      box-shadow:\n        0 0 0 2px #1e2a3a,\n        0 0 40px rgba(34, 211, 238, 0.15),\n        0 8px 40px rgba(0,0,0,0.6);\n    }\n\n    canvas {\n      display: block;\n      background: #0d1117;\n    }\n\n    #overlay {\n      position: absolute;\n      inset: 0;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      background: rgba(10, 12, 20, 0.88);\n      backdrop-filter: blur(4px);\n      border-radius: 12px;\n      transition: opacity 0.25s;\n    }\n\n    #overlay.hidden { opacity: 0; pointer-events: none; }\n\n    #overlay h2 {\n      font-size: 2rem;\n      font-weight: 800;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      color: #f87171;\n      margin-bottom: 0.4rem;\n    }\n\n    #overlay.start h2 { color: #4ade80; }\n\n    #overlay p {\n      color: #9ca3af;\n      font-size: 0.95rem;\n      margin-bottom: 0.25rem;\n    }\n\n    #overlay .final-score {\n      font-size: 1.2rem;\n      color: #e0e0e0;\n      margin-bottom: 1.4rem;\n    }\n\n    #overlay .final-score span { color: #4ade80; font-weight: 700; }\n\n    button {\n      padding: 0.65rem 2.2rem;\n      font-size: 1rem;\n      font-weight: 700;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      border: none;\n      border-radius: 8px;\n      cursor: pointer;\n      background: linear-gradient(135deg, #4ade80, #22d3ee);\n      color: #0f0f1a;\n      transition: transform 0.1s, box-shadow 0.1s;\n      box-shadow: 0 4px 18px rgba(74, 222, 128, 0.35);\n    }\n\n    button:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(74, 222, 128, 0.5); }\n    button:active { transform: translateY(0); }\n\n    #hint {\n      margin-top: 1rem;\n      font-size: 0.78rem;\n      color: #4b5563;\n      letter-spacing: 0.04em;\n    }\n  </style>\n</head>\n<body>\n\n<h1>Snake</h1>\n\n<div id=\"scoreboard\">\n  Score: <span id=\"score\">0</span>\n  &nbsp;&nbsp;|&nbsp;&nbsp;\n  Best: <span id=\"best\">0</span>\n</div>\n\n<div id=\"arena\">\n  <canvas id=\"canvas\"></canvas>\n\n  <div id=\"overlay\" class=\"start\">\n    <h2>Snake</h2>\n    <p>Use arrow keys to move</p>\n    <p class=\"final-score\" id=\"overlay-score\" style=\"display:none\"></p>\n    <button id=\"btn\">Play</button>\n  </div>\n</div>\n\n<div id=\"hint\">Press R to restart at any time</div>\n\n<script>\n  const COLS = 24, ROWS = 24, CELL = 22;\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n  canvas.width  = COLS * CELL;\n  canvas.height = ROWS * CELL;\n\n  const overlay      = document.getElementById('overlay');\n  const btn          = document.getElementById('btn');\n  const scoreEl      = document.getElementById('score');\n  const bestEl       = document.getElementById('best');\n  const overlayScore = document.getElementById('overlay-score');\n\n  let snake, dir, nextDir, food, score, best = 0, loopId, running = false;\n\n  // ── Colour helpers ──────────────────────────────────────────────────────────\n  function segColor(i, len) {\n    const t = i / Math.max(len - 1, 1);\n    // head: #4ade80  →  tail: #22d3ee\n    const r = Math.round(74  + (34  - 74)  * t);\n    const g = Math.round(222 + (211 - 222) * t);\n    const b = Math.round(128 + (238 - 128) * t);\n    return `rgb(${r},${g},${b})`;\n  }\n\n  // ── Drawing ─────────────────────────────────────────────────────────────────\n  function drawGrid() {\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n    ctx.strokeStyle = 'rgba(255,255,255,0.03)';\n    ctx.lineWidth = 0.5;\n    for (let c = 0; c <= COLS; c++) {\n      ctx.beginPath(); ctx.moveTo(c*CELL, 0); ctx.lineTo(c*CELL, canvas.height); ctx.stroke();\n    }\n    for (let r = 0; r <= ROWS; r++) {\n      ctx.beginPath(); ctx.moveTo(0, r*CELL); ctx.lineTo(canvas.width, r*CELL); ctx.stroke();\n    }\n  }\n\n  function roundRect(x, y, w, h, r) {\n    ctx.beginPath();\n    ctx.moveTo(x+r, y);\n    ctx.lineTo(x+w-r, y); ctx.arcTo(x+w, y,   x+w,   y+r,   r);\n    ctx.lineTo(x+w, y+h-r); ctx.arcTo(x+w, y+h, x+w-r, y+h,   r);\n    ctx.lineTo(x+r, y+h); ctx.arcTo(x,   y+h, x,     y+h-r, r);\n    ctx.lineTo(x, y+r); ctx.arcTo(x,   y,   x+r,   y,     r);\n    ctx.closePath();\n  }\n\n  function drawSnake() {\n    const pad = 2, r = 5;\n    snake.forEach((seg, i) => {\n      ctx.fillStyle = segColor(i, snake.length);\n      roundRect(seg.x*CELL+pad, seg.y*CELL+pad, CELL-pad*2, CELL-pad*2, r);\n      ctx.fill();\n\n      // subtle inner glow on head\n      if (i === 0) {\n        ctx.save();\n        ctx.globalAlpha = 0.35;\n        ctx.fillStyle = '#fff';\n        roundRect(seg.x*CELL+pad+3, seg.y*CELL+pad+3, CELL-pad*2-6, CELL-pad*2-6, r-2);\n        ctx.fill();\n        ctx.restore();\n      }\n    });\n  }\n\n  function drawFood() {\n    const cx = food.x*CELL + CELL/2;\n    const cy = food.y*CELL + CELL/2;\n    const radius = CELL/2 - 4;\n\n    // glow\n    const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, radius*2.2);\n    grd.addColorStop(0, 'rgba(248,113,113,0.35)');\n    grd.addColorStop(1, 'rgba(248,113,113,0)');\n    ctx.fillStyle = grd;\n    ctx.beginPath(); ctx.arc(cx, cy, radius*2.2, 0, Math.PI*2); ctx.fill();\n\n    // body\n    const grad = ctx.createRadialGradient(cx-2, cy-2, 0, cx, cy, radius);\n    grad.addColorStop(0, '#fca5a5');\n    grad.addColorStop(1, '#ef4444');\n    ctx.fillStyle = grad;\n    ctx.beginPath(); ctx.arc(cx, cy, radius, 0, Math.PI*2); ctx.fill();\n  }\n\n  function render() {\n    drawGrid();\n    drawFood();\n    drawSnake();\n  }\n\n  // ── Game logic ───────────────────────────────────────────────────────────────\n  function placeFood() {\n    const free = [];\n    for (let x = 0; x < COLS; x++)\n      for (let y = 0; y < ROWS; y++)\n        if (!snake.some(s => s.x===x && s.y===y)) free.push({x,y});\n    food = free[Math.floor(Math.random()*free.length)];\n  }\n\n  function init() {\n    const mx = Math.floor(COLS/2), my = Math.floor(ROWS/2);\n    snake   = [{x:mx,y:my},{x:mx-1,y:my},{x:mx-2,y:my}];\n    dir     = {x:1, y:0};\n    nextDir = {x:1, y:0};\n    score   = 0;\n    scoreEl.textContent = 0;\n    placeFood();\n  }\n\n  function step() {\n    dir = nextDir;\n    const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };\n\n    // wall collision\n    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) return gameOver();\n    // self collision\n    if (snake.some(s => s.x===head.x && s.y===head.y)) return gameOver();\n\n    snake.unshift(head);\n\n    if (head.x === food.x && head.y === food.y) {\n      score++;\n      scoreEl.textContent = score;\n      if (score > best) { best = score; bestEl.textContent = best; }\n      placeFood();\n    } else {\n      snake.pop();\n    }\n    render();\n  }\n\n  function gameOver() {\n    running = false;\n    clearInterval(loopId);\n    overlay.classList.remove('start', 'hidden');\n    overlay.querySelector('h2').textContent = 'Game Over';\n    overlayScore.style.display = '';\n    overlayScore.innerHTML = `Score: <span>${score}</span>`;\n    btn.textContent = 'Restart';\n  }\n\n  function startGame() {\n    init();\n    render();\n    running = true;\n    overlay.classList.add('hidden');\n    clearInterval(loopId);\n    loopId = setInterval(step, 110);\n  }\n\n  // ── Input ────────────────────────────────────────────────────────────────────\n  const keyMap = {\n    ArrowUp:    {x:0,  y:-1},\n    ArrowDown:  {x:0,  y:1},\n    ArrowLeft:  {x:-1, y:0},\n    ArrowRight: {x:1,  y:0},\n    w: {x:0,y:-1}, W: {x:0,y:-1},\n    s: {x:0,y:1},  S: {x:0,y:1},\n    a: {x:-1,y:0}, A: {x:-1,y:0},\n    d: {x:1,y:0},  D: {x:1,y:0},\n  };\n\n  document.addEventListener('keydown', e => {\n    if (e.key === 'r' || e.key === 'R') { startGame(); return; }\n    const d = keyMap[e.key];\n    if (!d) return;\n    // prevent 180° reversal\n    if (d.x !== -dir.x || d.y !== -dir.y) nextDir = d;\n    // prevent arrow keys from scrolling\n    if (e.key.startsWith('Arrow')) e.preventDefault();\n  });\n\n  btn.addEventListener('click', startGame);\n\n  // initial render (no game yet)\n  init();\n  render();\n</script>\n</body>\n</html>\n"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/t969275/Code/Scienta/multisnake/claude-sonnet-4.6/index.html","exists":false,"truncated":false},"title":"Users/t969275/Code/Scienta/multisnake/claude-sonnet-4.6/index.html","time":{"start":1777038249031,"end":1777038249042}},"id":"prt_dbfbb338c001TjkqQ2SpsFjj57","sessionID":"ses_24044e3ebffeI2SkdKQLUEjELW","messageID":"msg_dbfbb20fd001Lmp8s2lllH5T0Q"}}
