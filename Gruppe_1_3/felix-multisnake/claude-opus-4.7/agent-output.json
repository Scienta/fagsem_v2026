{"type":"tool_use","timestamp":1777038267095,"sessionID":"ses_24044c7ebffeoFg2MZRQPbU2aj","part":{"type":"tool","tool":"write","callID":"toolu_01XSrYKabSpfnXt6GVZAETRb","state":{"status":"completed","input":{"filePath":"/Users/t969275/Code/Scienta/multisnake/claude-opus-4.7/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n<title>Snake</title>\n<style>\n  :root {\n    --bg-0: #0f172a;\n    --bg-1: #1e293b;\n    --accent: #22d3ee;\n    --accent-2: #a78bfa;\n    --snake: #4ade80;\n    --snake-head: #16a34a;\n    --food: #f43f5e;\n    --text: #e2e8f0;\n    --muted: #94a3b8;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    height: 100%;\n    margin: 0;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n    color: var(--text);\n    background: radial-gradient(ellipse at top, #1e293b, #0f172a 70%);\n    overflow: hidden;\n  }\n\n  .app {\n    min-height: 100vh;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    padding: 20px;\n    gap: 18px;\n  }\n\n  .title {\n    font-size: clamp(28px, 5vw, 44px);\n    font-weight: 800;\n    letter-spacing: 2px;\n    background: linear-gradient(90deg, var(--accent), var(--accent-2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    margin: 0;\n    text-transform: uppercase;\n  }\n\n  .hud {\n    display: flex;\n    gap: 20px;\n    align-items: center;\n    background: rgba(15, 23, 42, 0.6);\n    backdrop-filter: blur(10px);\n    border: 1px solid rgba(148, 163, 184, 0.15);\n    padding: 10px 18px;\n    border-radius: 12px;\n    box-shadow: 0 10px 30px rgba(0,0,0,0.3);\n  }\n\n  .hud .stat {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    min-width: 80px;\n  }\n\n  .hud .label {\n    font-size: 11px;\n    text-transform: uppercase;\n    letter-spacing: 1.5px;\n    color: var(--muted);\n  }\n\n  .hud .value {\n    font-size: 22px;\n    font-weight: 700;\n    color: var(--text);\n    font-variant-numeric: tabular-nums;\n  }\n\n  .board-wrap {\n    position: relative;\n    border-radius: 16px;\n    padding: 8px;\n    background: linear-gradient(135deg, rgba(34,211,238,0.25), rgba(167,139,250,0.25));\n    box-shadow: 0 20px 60px rgba(0,0,0,0.45);\n  }\n\n  canvas {\n    display: block;\n    background: #0b1220;\n    border-radius: 10px;\n    image-rendering: pixelated;\n  }\n\n  .overlay {\n    position: absolute;\n    inset: 8px;\n    background: rgba(11, 18, 32, 0.88);\n    border-radius: 10px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    gap: 14px;\n    text-align: center;\n    padding: 20px;\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity 0.25s ease;\n  }\n\n  .overlay.visible {\n    opacity: 1;\n    pointer-events: auto;\n  }\n\n  .overlay h2 {\n    margin: 0;\n    font-size: 32px;\n    letter-spacing: 1px;\n  }\n\n  .overlay p {\n    margin: 0;\n    color: var(--muted);\n    max-width: 320px;\n    line-height: 1.5;\n  }\n\n  .btn {\n    padding: 12px 26px;\n    border: none;\n    border-radius: 999px;\n    background: linear-gradient(90deg, var(--accent), var(--accent-2));\n    color: #0b1220;\n    font-weight: 700;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    cursor: pointer;\n    font-size: 14px;\n    transition: transform 0.15s ease, box-shadow 0.15s ease;\n    box-shadow: 0 6px 20px rgba(34, 211, 238, 0.35);\n  }\n\n  .btn:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(34, 211, 238, 0.45); }\n  .btn:active { transform: translateY(0); }\n\n  .hint {\n    color: var(--muted);\n    font-size: 13px;\n    letter-spacing: 0.5px;\n  }\n\n  kbd {\n    background: rgba(148, 163, 184, 0.15);\n    border: 1px solid rgba(148, 163, 184, 0.25);\n    padding: 2px 6px;\n    border-radius: 4px;\n    font-family: inherit;\n    font-size: 11px;\n    color: var(--text);\n  }\n</style>\n</head>\n<body>\n  <div class=\"app\">\n    <h1 class=\"title\">Snake</h1>\n    <div class=\"hud\">\n      <div class=\"stat\">\n        <span class=\"label\">Score</span>\n        <span class=\"value\" id=\"score\">0</span>\n      </div>\n      <div class=\"stat\">\n        <span class=\"label\">Best</span>\n        <span class=\"value\" id=\"best\">0</span>\n      </div>\n      <div class=\"stat\">\n        <span class=\"label\">Speed</span>\n        <span class=\"value\" id=\"speed\">1</span>\n      </div>\n    </div>\n\n    <div class=\"board-wrap\">\n      <canvas id=\"game\" width=\"480\" height=\"480\"></canvas>\n      <div class=\"overlay visible\" id=\"overlay\">\n        <h2 id=\"overlay-title\">Ready?</h2>\n        <p id=\"overlay-text\">Use the arrow keys or <kbd>W</kbd> <kbd>A</kbd> <kbd>S</kbd> <kbd>D</kbd> to move. Press <kbd>Space</kbd> to pause.</p>\n        <button class=\"btn\" id=\"start-btn\">Start</button>\n      </div>\n    </div>\n\n    <div class=\"hint\">Arrows / WASD to move &middot; Space to pause &middot; R to restart</div>\n  </div>\n\n<script>\n(function () {\n  const canvas = document.getElementById('game');\n  const ctx = canvas.getContext('2d');\n  const scoreEl = document.getElementById('score');\n  const bestEl = document.getElementById('best');\n  const speedEl = document.getElementById('speed');\n  const overlay = document.getElementById('overlay');\n  const overlayTitle = document.getElementById('overlay-title');\n  const overlayText = document.getElementById('overlay-text');\n  const startBtn = document.getElementById('start-btn');\n\n  const COLS = 24;\n  const ROWS = 24;\n  const CELL = canvas.width / COLS;\n\n  const STATE = { MENU: 'menu', PLAYING: 'playing', PAUSED: 'paused', OVER: 'over' };\n\n  let snake, dir, nextDir, food, score, best, state, tickInterval, lastTick, speedLevel;\n\n  best = parseInt(localStorage.getItem('snake-best') || '0', 10);\n  bestEl.textContent = best;\n\n  function reset() {\n    snake = [\n      { x: 10, y: 12 },\n      { x: 9, y: 12 },\n      { x: 8, y: 12 },\n    ];\n    dir = { x: 1, y: 0 };\n    nextDir = { x: 1, y: 0 };\n    score = 0;\n    speedLevel = 1;\n    tickInterval = 130;\n    scoreEl.textContent = '0';\n    speedEl.textContent = '1';\n    placeFood();\n  }\n\n  function placeFood() {\n    while (true) {\n      const fx = Math.floor(Math.random() * COLS);\n      const fy = Math.floor(Math.random() * ROWS);\n      if (!snake.some(s => s.x === fx && s.y === fy)) {\n        food = { x: fx, y: fy };\n        return;\n      }\n    }\n  }\n\n  function showOverlay(title, text, btnLabel) {\n    overlayTitle.textContent = title;\n    overlayText.innerHTML = text;\n    startBtn.textContent = btnLabel;\n    overlay.classList.add('visible');\n  }\n\n  function hideOverlay() {\n    overlay.classList.remove('visible');\n  }\n\n  function startGame() {\n    reset();\n    state = STATE.PLAYING;\n    hideOverlay();\n    lastTick = performance.now();\n    requestAnimationFrame(loop);\n  }\n\n  function gameOver() {\n    state = STATE.OVER;\n    if (score > best) {\n      best = score;\n      localStorage.setItem('snake-best', String(best));\n      bestEl.textContent = best;\n    }\n    showOverlay('Game Over', `You scored <strong>${score}</strong>. Press <kbd>R</kbd> or click below to play again.`, 'Play Again');\n  }\n\n  function togglePause() {\n    if (state === STATE.PLAYING) {\n      state = STATE.PAUSED;\n      showOverlay('Paused', 'Press <kbd>Space</kbd> to resume.', 'Resume');\n    } else if (state === STATE.PAUSED) {\n      state = STATE.PLAYING;\n      hideOverlay();\n      lastTick = performance.now();\n      requestAnimationFrame(loop);\n    }\n  }\n\n  function step() {\n    // prevent 180 turns\n    if ((nextDir.x !== -dir.x || nextDir.y !== -dir.y)) {\n      dir = nextDir;\n    }\n\n    const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };\n\n    // wall collision\n    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) {\n      gameOver();\n      return;\n    }\n\n    // self collision\n    for (let i = 0; i < snake.length; i++) {\n      if (snake[i].x === head.x && snake[i].y === head.y) {\n        gameOver();\n        return;\n      }\n    }\n\n    snake.unshift(head);\n\n    if (head.x === food.x && head.y === food.y) {\n      score += 10;\n      scoreEl.textContent = score;\n      // speed up every 5 foods\n      const newLevel = 1 + Math.floor(score / 50);\n      if (newLevel !== speedLevel) {\n        speedLevel = newLevel;\n        speedEl.textContent = speedLevel;\n        tickInterval = Math.max(60, 130 - (speedLevel - 1) * 10);\n      }\n      placeFood();\n    } else {\n      snake.pop();\n    }\n  }\n\n  function drawGrid() {\n    ctx.fillStyle = '#0b1220';\n    ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n    // subtle checker\n    for (let y = 0; y < ROWS; y++) {\n      for (let x = 0; x < COLS; x++) {\n        if ((x + y) % 2 === 0) {\n          ctx.fillStyle = 'rgba(255,255,255,0.015)';\n          ctx.fillRect(x * CELL, y * CELL, CELL, CELL);\n        }\n      }\n    }\n  }\n\n  function roundRect(x, y, w, h, r) {\n    ctx.beginPath();\n    ctx.moveTo(x + r, y);\n    ctx.arcTo(x + w, y, x + w, y + h, r);\n    ctx.arcTo(x + w, y + h, x, y + h, r);\n    ctx.arcTo(x, y + h, x, y, r);\n    ctx.arcTo(x, y, x + w, y, r);\n    ctx.closePath();\n  }\n\n  function drawFood() {\n    const cx = food.x * CELL + CELL / 2;\n    const cy = food.y * CELL + CELL / 2;\n    const pulse = 1 + Math.sin(performance.now() / 200) * 0.08;\n    const r = (CELL / 2 - 2) * pulse;\n\n    const grad = ctx.createRadialGradient(cx - r/3, cy - r/3, 1, cx, cy, r);\n    grad.addColorStop(0, '#fda4af');\n    grad.addColorStop(1, '#e11d48');\n    ctx.fillStyle = grad;\n    ctx.beginPath();\n    ctx.arc(cx, cy, r, 0, Math.PI * 2);\n    ctx.fill();\n  }\n\n  function drawSnake() {\n    for (let i = snake.length - 1; i >= 0; i--) {\n      const s = snake[i];\n      const isHead = i === 0;\n      const pad = 1.5;\n      const x = s.x * CELL + pad;\n      const y = s.y * CELL + pad;\n      const size = CELL - pad * 2;\n\n      if (isHead) {\n        const grad = ctx.createLinearGradient(x, y, x + size, y + size);\n        grad.addColorStop(0, '#4ade80');\n        grad.addColorStop(1, '#16a34a');\n        ctx.fillStyle = grad;\n      } else {\n        const t = i / snake.length;\n        const g = Math.floor(163 - t * 40);\n        ctx.fillStyle = `rgb(74, ${g + 40}, 128)`;\n        ctx.fillStyle = `hsl(${140 - t * 10}, ${60 - t * 20}%, ${55 - t * 15}%)`;\n      }\n\n      roundRect(x, y, size, size, 4);\n      ctx.fill();\n\n      if (isHead) {\n        // eyes\n        ctx.fillStyle = '#0b1220';\n        const eyeSize = 2.2;\n        const cx = x + size / 2;\n        const cy = y + size / 2;\n        const ox = dir.x * (size / 4);\n        const oy = dir.y * (size / 4);\n        const px = -dir.y * (size / 5);\n        const py = dir.x * (size / 5);\n        ctx.beginPath();\n        ctx.arc(cx + ox + px, cy + oy + py, eyeSize, 0, Math.PI * 2);\n        ctx.arc(cx + ox - px, cy + oy - py, eyeSize, 0, Math.PI * 2);\n        ctx.fill();\n      }\n    }\n  }\n\n  function draw() {\n    drawGrid();\n    drawFood();\n    drawSnake();\n  }\n\n  function loop(now) {\n    if (state !== STATE.PLAYING) return;\n    const elapsed = now - lastTick;\n    if (elapsed >= tickInterval) {\n      lastTick = now - (elapsed % tickInterval);\n      step();\n    }\n    draw();\n    requestAnimationFrame(loop);\n  }\n\n  // Controls\n  const keyMap = {\n    ArrowUp: { x: 0, y: -1 }, KeyW: { x: 0, y: -1 },\n    ArrowDown: { x: 0, y: 1 }, KeyS: { x: 0, y: 1 },\n    ArrowLeft: { x: -1, y: 0 }, KeyA: { x: -1, y: 0 },\n    ArrowRight: { x: 1, y: 0 }, KeyD: { x: 1, y: 0 },\n  };\n\n  window.addEventListener('keydown', (e) => {\n    if (keyMap[e.code]) {\n      e.preventDefault();\n      if (state === STATE.PLAYING) nextDir = keyMap[e.code];\n    } else if (e.code === 'Space') {\n      e.preventDefault();\n      if (state === STATE.MENU || state === STATE.OVER) startGame();\n      else togglePause();\n    } else if (e.code === 'KeyR') {\n      e.preventDefault();\n      startGame();\n    } else if (e.code === 'Enter') {\n      if (state === STATE.MENU || state === STATE.OVER) startGame();\n    }\n  });\n\n  startBtn.addEventListener('click', () => {\n    if (state === STATE.PAUSED) togglePause();\n    else startGame();\n  });\n\n  // Initial render\n  state = STATE.MENU;\n  reset();\n  draw();\n})();\n</script>\n</body>\n</html>\n"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/t969275/Code/Scienta/multisnake/claude-opus-4.7/index.html","exists":false,"truncated":false},"title":"Users/t969275/Code/Scienta/multisnake/claude-opus-4.7/index.html","time":{"start":1777038267084,"end":1777038267094}},"metadata":{"anthropic":{"caller":{"type":"direct"}}},"id":"prt_dbfbb59a7001IM0XEzMvpWAK9J","sessionID":"ses_24044c7ebffeoFg2MZRQPbU2aj","messageID":"msg_dbfbb4f9d001Wdqwk9RJqrjOHY"}}
