{"type":"tool_use","timestamp":1777038236097,"sessionID":"ses_24044d813ffek3Qk6T7mpygqf1","part":{"type":"tool","tool":"write","callID":"call_MHxHejQxdzh0cG9qWXFPbkNHUUo","state":{"status":"completed","input":{"content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Snake Game</title>\n    <style>\n        :root {\n            --bg-color: #1a1a2e;\n            --container-bg: #16213e;\n            --canvas-bg: #0f3460;\n            --snake-color: #4ecca3;\n            --food-color: #e94560;\n            --text-color: #eeeeee;\n        }\n\n        body {\n            margin: 0;\n            padding: 0;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            height: 100vh;\n            background-color: var(--bg-color);\n            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n            color: var(--text-color);\n        }\n\n        #game-container {\n            background-color: var(--container-bg);\n            padding: 20px 30px;\n            border-radius: 15px;\n            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);\n            text-align: center;\n            position: relative;\n        }\n\n        .header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 15px;\n        }\n\n        h1 {\n            margin: 0;\n            font-size: 24px;\n            text-transform: uppercase;\n            letter-spacing: 2px;\n            color: var(--snake-color);\n        }\n\n        #score-board {\n            font-size: 20px;\n            font-weight: bold;\n        }\n\n        canvas {\n            background-color: var(--canvas-bg);\n            border-radius: 8px;\n            box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.5);\n            display: block;\n        }\n\n        #overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(22, 33, 62, 0.85);\n            border-radius: 15px;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            z-index: 10;\n            opacity: 0;\n            pointer-events: none;\n            transition: opacity 0.3s ease;\n        }\n\n        #overlay.active {\n            opacity: 1;\n            pointer-events: auto;\n        }\n\n        #game-over-text {\n            font-size: 36px;\n            font-weight: bold;\n            color: var(--food-color);\n            margin-bottom: 10px;\n            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);\n        }\n\n        #final-score {\n            font-size: 20px;\n            margin-bottom: 25px;\n        }\n\n        button {\n            background-color: var(--snake-color);\n            color: var(--bg-color);\n            border: none;\n            padding: 12px 24px;\n            font-size: 18px;\n            font-weight: bold;\n            border-radius: 25px;\n            cursor: pointer;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            transition: transform 0.2s, box-shadow 0.2s, background-color 0.2s;\n        }\n\n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 5px 15px rgba(78, 204, 163, 0.4);\n            background-color: #5ce0b5;\n        }\n\n        button:active {\n            transform: translateY(0);\n        }\n\n        .controls-hint {\n            margin-top: 15px;\n            font-size: 12px;\n            color: #888;\n        }\n    </style>\n</head>\n<body>\n\n    <div id=\"game-container\">\n        <div class=\"header\">\n            <h1>Snake</h1>\n            <div id=\"score-board\">Score: <span id=\"score\">0</span></div>\n        </div>\n        \n        <canvas id=\"gameCanvas\" width=\"400\" height=\"400\"></canvas>\n        \n        <div id=\"overlay\">\n            <div id=\"game-over-text\">Game Over!</div>\n            <div id=\"final-score\">Final Score: <span>0</span></div>\n            <button id=\"restart-btn\">Play Again</button>\n        </div>\n\n        <div class=\"controls-hint\">Use Arrow Keys to move</div>\n    </div>\n\n    <script>\n        const canvas = document.getElementById(\"gameCanvas\");\n        const ctx = canvas.getContext(\"2d\");\n        const scoreElement = document.getElementById(\"score\");\n        const overlay = document.getElementById(\"overlay\");\n        const finalScoreElement = document.querySelector(\"#final-score span\");\n        const restartBtn = document.getElementById(\"restart-btn\");\n\n        // Game configuration\n        const gridSize = 20;\n        const tileCount = canvas.width / gridSize;\n        let gameSpeed = 100; // ms per frame\n\n        // Colors\n        const snakeColor = getComputedStyle(document.documentElement).getPropertyValue('--snake-color').trim();\n        const snakeHeadColor = '#5ce0b5';\n        const foodColor = getComputedStyle(document.documentElement).getPropertyValue('--food-color').trim();\n\n        // Game state\n        let snake = [];\n        let dx = 0;\n        let dy = 0;\n        let foodX = 0;\n        let foodY = 0;\n        let score = 0;\n        let gameLoop;\n        let isGameOver = false;\n        let nextDx = 0;\n        let nextDy = 0;\n\n        function initGame() {\n            // Reset state\n            snake = [\n                { x: 10, y: 10 },\n            ];\n            dx = 0;\n            dy = 0;\n            nextDx = 0;\n            nextDy = 0;\n            score = 0;\n            gameSpeed = 120;\n            isGameOver = false;\n            \n            scoreElement.innerText = score;\n            overlay.classList.remove('active');\n            \n            placeFood();\n            \n            // Clear existing interval if any\n            if (gameLoop) clearTimeout(gameLoop);\n            \n            // Start loop\n            main();\n        }\n\n        function main() {\n            if (isGameOver) return;\n\n            gameLoop = setTimeout(function onTick() {\n                clearCanvas();\n                moveSnake();\n                checkCollision();\n                if (!isGameOver) {\n                    drawFood();\n                    drawSnake();\n                    main();\n                }\n            }, gameSpeed);\n        }\n\n        function clearCanvas() {\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n        }\n\n        function drawSnake() {\n            snake.forEach((segment, index) => {\n                ctx.fillStyle = index === 0 ? snakeHeadColor : snakeColor;\n                \n                // Add a slight margin for grid effect\n                ctx.fillRect(segment.x * gridSize + 1, segment.y * gridSize + 1, gridSize - 2, gridSize - 2);\n            });\n        }\n\n        function moveSnake() {\n            // Update actual direction from buffered input\n            dx = nextDx;\n            dy = nextDy;\n\n            // If not moving, don't update positions\n            if (dx === 0 && dy === 0) return;\n\n            const head = { x: snake[0].x + dx, y: snake[0].y + dy };\n            snake.unshift(head);\n\n            if (head.x === foodX && head.y === foodY) {\n                score += 10;\n                scoreElement.innerText = score;\n                // Increase speed slightly\n                if (gameSpeed > 50) gameSpeed -= 2;\n                placeFood();\n            } else {\n                snake.pop();\n            }\n        }\n\n        function drawFood() {\n            ctx.fillStyle = foodColor;\n            \n            // Draw a circular food\n            ctx.beginPath();\n            ctx.arc(\n                foodX * gridSize + gridSize / 2, \n                foodY * gridSize + gridSize / 2, \n                gridSize / 2 - 2, \n                0, \n                2 * Math.PI\n            );\n            ctx.fill();\n        }\n\n        function placeFood() {\n            foodX = Math.floor(Math.random() * tileCount);\n            foodY = Math.floor(Math.random() * tileCount);\n\n            // Make sure food doesn't spawn on the snake\n            const isOnSnake = snake.some(segment => segment.x === foodX && segment.y === foodY);\n            if (isOnSnake) {\n                placeFood();\n            }\n        }\n\n        function checkCollision() {\n            const head = snake[0];\n\n            // Wall collision\n            if (head.x < 0 || head.x >= tileCount || head.y < 0 || head.y >= tileCount) {\n                handleGameOver();\n            }\n\n            // Self collision (start checking from index 4 because it's impossible to hit the first 3 body parts)\n            for (let i = 4; i < snake.length; i++) {\n                if (head.x === snake[i].x && head.y === snake[i].y) {\n                    handleGameOver();\n                }\n            }\n        }\n\n        function handleGameOver() {\n            isGameOver = true;\n            finalScoreElement.innerText = score;\n            overlay.classList.add('active');\n        }\n\n        // Key controls\n        document.addEventListener(\"keydown\", (event) => {\n            // Prevent default scrolling for arrow keys\n            if([\"ArrowUp\",\"ArrowDown\",\"ArrowLeft\",\"ArrowRight\"].indexOf(event.code) > -1) {\n                event.preventDefault();\n            }\n\n            const key = event.key;\n            \n            // Prevent reversing direction directly\n            if (key === \"ArrowUp\" && dy !== 1) {\n                nextDx = 0;\n                nextDy = -1;\n            } else if (key === \"ArrowDown\" && dy !== -1) {\n                nextDx = 0;\n                nextDy = 1;\n            } else if (key === \"ArrowLeft\" && dx !== 1) {\n                nextDx = -1;\n                nextDy = 0;\n            } else if (key === \"ArrowRight\" && dx !== -1) {\n                nextDx = 1;\n                nextDy = 0;\n            }\n        });\n\n        restartBtn.addEventListener(\"click\", initGame);\n\n        // Draw initial state before starting\n        clearCanvas();\n        initGame();\n        // Pause until first move\n        dx = 0;\n        dy = 0;\n        nextDx = 0;\n        nextDy = 0;\n        \n    </script>\n</body>\n</html>","filePath":"/Users/t969275/Code/Scienta/multisnake/gemini-3.1-pro-preview/index.html"},"output":"Wrote file successfully.","metadata":{"diagnostics":{},"filepath":"/Users/t969275/Code/Scienta/multisnake/gemini-3.1-pro-preview/index.html","exists":false,"truncated":false},"title":"Users/t969275/Code/Scienta/multisnake/gemini-3.1-pro-preview/index.html","time":{"start":1777038236078,"end":1777038236092}},"metadata":{"copilot":{"reasoningOpaque":""}},"id":"prt_dbfbb99a9001OSrgiZB2xv3hPm","sessionID":"ses_24044d813ffek3Qk6T7mpygqf1","messageID":"msg_dbfbb2c7f001KaGVrWcnvCcE1s"}}
